{
  "dataset": "hotpotqa",
  "split": "validation",
  "samples": 200,
  "top_k": 5,
  "prf_threshold": 0.8,
  "generator_backend": "deepseek",
  "generator_model": "deepseek-v4-flash",
  "verifier_backend": "deepseek",
  "verifier_model": "deepseek-v4-flash",
  "real_cove": true,
  "device": "cuda",
  "local_data_dir": "data/datasets",
  "hf_cache_dir": null,
  "offline": true,
  "output_name": "verifier_comparison_hotpotqa.json",
  "verifiers": [
    { "name": "cove_soft", "mode": "cove", "threshold": 0.35 },
    { "name": "cove_standard", "mode": "cove", "threshold": 0.5 },
    { "name": "cove_strict", "mode": "cove", "threshold": 0.9 },
    { "name": "overlap_soft", "mode": "overlap", "threshold": 0.35 }
  ]
}
